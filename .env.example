# ── Required ──────────────────────────────────────────────────────────────────
# Serper API — https://serper.dev (free tier: 2,500 queries)
SERPER_API_KEY=

# OpenRouter API — https://openrouter.ai
OPENROUTER_API_KEY=

# Model for AI analysis. Options:
#   anthropic/claude-sonnet-4-5   (~$3/M tokens, best quality)
#   anthropic/claude-haiku-4-5    (~$0.25/M tokens, fast & cheap)
#   google/gemini-flash-1.5       (~$0.075/M tokens, budget)
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# ── Recommended ───────────────────────────────────────────────────────────────
# Firecrawl API — https://firecrawl.dev (free tier: 1,000 credits/month)
# Without this key, free Jina fallback is used (slower, may miss JS-heavy sites)
FIRECRAWL_API_KEY=

# Google Sheets — exact name of the sheet to write to
GOOGLE_SHEET_NAME=COMPETITOR_LIST_APOSTILLE_BUSINESS

# Path to your OAuth 2.0 Desktop App client secrets JSON
# Download from: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs → Desktop app → Download JSON
OAUTH_CREDENTIALS_PATH=credentials.json

# ── Optional: Domain Authority ────────────────────────────────────────────────
# Get a free API key at https://openpagerank.com/
OPEN_PAGERANK_API_KEY=

# ── Optional: Notifications ───────────────────────────────────────────────────
# Slack incoming webhook — https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Email alerts via SMTP (Gmail App Password recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_here
ALERT_EMAIL=recipient@example.com
